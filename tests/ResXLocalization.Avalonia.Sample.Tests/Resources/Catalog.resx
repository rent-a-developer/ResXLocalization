<?xml version="1.0" encoding="utf-8"?>
<root>
  <!--
    Test-only resource file. It has no .Designer.cs, so the typed-key generator skips it; the tests load
    it through a plain ResourceManager. It defines:
      * Shared            - also defined in Fallback.resx, to test search-all first-match-wins and scoping.
      * CatalogOnly       - unique to this file, to prove search-all reaches it.
      * Display_*         - custom-prefix enum keys, to test scoped custom-prefix enum lookups.
      * FormatPair        - a two-argument composite format string, for the LocalizeArgs tests.
      * FormatGap         - references {0} and {2}, to test a higher argument slot used alone.
      * CurlyNoArgs       - literal braces, to prove the no-argument path never composite-formats.
  -->
  <resheader name="resmimetype">
    <value>text/microsoft-resx</value>
  </resheader>
  <resheader name="version">
    <value>2.0</value>
  </resheader>
  <resheader name="reader">
    <value>System.Resources.ResXResourceReader, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value>
  </resheader>
  <resheader name="writer">
    <value>System.Resources.ResXResourceWriter, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value>
  </resheader>
  <data name="Shared" xml:space="preserve">
    <value>CatalogShared</value>
  </data>
  <data name="CatalogOnly" xml:space="preserve">
    <value>CatalogOnlyValue</value>
  </data>
  <data name="Display_FileSortOrder_Ascending" xml:space="preserve">
    <value>CatalogAscending</value>
  </data>
  <data name="FormatPair" xml:space="preserve">
    <value>File {0} of {1}</value>
  </data>
  <data name="FormatGap" xml:space="preserve">
    <value>[{0}|{2}]</value>
  </data>
  <data name="CurlyNoArgs" xml:space="preserve">
    <value>Literal {braces} stay</value>
  </data>
</root>
