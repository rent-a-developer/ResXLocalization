<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- An isolated package cache: the freshly packed 1.0.0 must never collide with (or pollute)
         the machine-wide cache. Delete this folder to pick up a re-packed build locally. -->
    <add key="globalPackagesFolder" value=".packages" />
  </config>
  <packageSources>
    <clear />
    <!-- The packages under test, produced by `dotnet pack ... -o artifacts/packages`. -->
    <add key="local-packages" value="../../artifacts/packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
